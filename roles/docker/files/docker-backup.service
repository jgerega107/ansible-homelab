[Unit]
Description=Docker Volume Backup
After=docker.service
Requires=docker.service
RequiresMountsFor=/mnt/tank
ConditionPathIsMountPoint=/mnt/tank

[Service]
Type=oneshot
EnvironmentFile=/etc/restic/backup.env
ExecStart=/usr/local/sbin/backup_docker_volumes
User=root
WorkingDirectory=/srv/docker

[Install]
WantedBy=multi-user.target
