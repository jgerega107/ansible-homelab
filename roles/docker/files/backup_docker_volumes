#!/bin/bash

# Docker Backup Script using Restic over SFTP
# Backs up the entire /srv/docker directory in a single snapshot

# Configuration
DATA_DIR="/srv/docker"
LABEL_STOP="backup.stop"
PROMETHEUS_TEXTFILE_DIR="/var/lib/node_exporter"

# Script state
FAILED=0
DRY_RUN=0
STOPPED_CONTAINERS=()

set -eo pipefail

usage() {
    cat << EOF
Usage: $0 [OPTIONS]

Options:
  --dry-run              Show what would be done without executing
  -h, --help             Show this help message

Environment Variables:
  RESTIC_REPOSITORY      Restic repository location (can be restic repository format for SFTP,etc)
  RESTIC_PASSWORD        Restic password (or use RESTIC_PASSWORD_FILE)
  RESTIC_PASSWORD_FILE   Path to file containing restic password

Examples:
  $0                                          # Run backup
  $0 --dry-run                                # Show what would be done

Backup Structure:
  - Single snapshot of entire /srv/docker directory
  - Containers with backup.stop=true label are stopped during backup

EOF
    exit 1
}

log_info() {
    echo "[INFO] $1"
}

log_warn() {
    echo "[WARN] $1" >&2
}

log_error() {
    echo "[ERROR] $1" >&2
}

write_prometheus_metric() {
    local success=$1
    local temp_file="${PROMETHEUS_TEXTFILE_DIR}/docker_backup.prom.tmp"
    local final_file="${PROMETHEUS_TEXTFILE_DIR}/docker_backup.prom"

    if [[ $DRY_RUN -eq 1 ]]; then
        return
    fi

    cat > "$temp_file" << EOF
docker_backup_success ${success}
docker_backup_timestamp $(date +%s)
EOF
    mv "$temp_file" "$final_file"
}

cleanup() {
    local exit_code=$?

    # Always restart containers that were stopped, even on failure
    if [[ ${#STOPPED_CONTAINERS[@]} -gt 0 ]]; then
        log_info "Restarting stopped containers..."
        for container_info in "${STOPPED_CONTAINERS[@]}"; do
            local container_id="${container_info%%:*}"
            local container_name="${container_info##*:}"

            if [[ $DRY_RUN -eq 0 ]]; then
                log_info "Starting container: $container_name"
                docker start "$container_id" || log_warn "Failed to restart container $container_name"
            else
                log_info "[DRY RUN] Would start container: $container_name"
            fi
        done
    fi

    if [[ $DRY_RUN -eq 0 ]]; then
        if [[ $exit_code -ne 0 || $FAILED -ne 0 ]]; then
            write_prometheus_metric 0
        else
            write_prometheus_metric 1
        fi
    fi
}

trap cleanup EXIT

# Parse arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        --dry-run)
            DRY_RUN=1
            log_info "Dry run mode enabled. No actions will be performed."
            shift
            ;;
        -h|--help)
            usage
            ;;
        *)
            log_error "Unknown option: $1"
            usage
            ;;
    esac
done

# Validate restic is installed
if ! command -v restic &> /dev/null; then
    log_error "restic binary not found. Please install restic."
    exit 1
fi

# Validate directories exist
if [[ ! -d "$DATA_DIR" ]]; then
    log_error "Backup directory does not exist: $DATA_DIR"
    exit 1
fi

if [[ ! -d "$PROMETHEUS_TEXTFILE_DIR" ]]; then
    log_error "Prometheus textfile directory does not exist: $PROMETHEUS_TEXTFILE_DIR"
    exit 1
fi

if [[ ! -w "$PROMETHEUS_TEXTFILE_DIR" ]]; then
    log_error "Prometheus textfile directory is not writable: $PROMETHEUS_TEXTFILE_DIR"
    exit 1
fi

# Set up restic environment
export RESTIC_REPOSITORY

if [[ -n "$RESTIC_PASSWORD" ]]; then
    export RESTIC_PASSWORD
    log_info "Using RESTIC_PASSWORD from environment"
elif [[ -n "$RESTIC_PASSWORD_FILE" && -f "$RESTIC_PASSWORD_FILE" ]]; then
    export RESTIC_PASSWORD_FILE
    log_info "Using RESTIC_PASSWORD_FILE: $RESTIC_PASSWORD_FILE"
else
    log_error "No restic password provided. Set RESTIC_PASSWORD or RESTIC_PASSWORD_FILE environment variable."
    exit 1
fi

# Initialize restic repo if needed
init_restic_repo() {
    log_info "Checking restic repository..."

    if ! restic cat config > /dev/null 2>&1; then
        log_error "Restic repository not found or not accessible: $RESTIC_REPOSITORY"
        log_error "Please initialize the repository manually with: restic init"
        exit 1
    fi
}

# Get all running containers with the backup.stop label
get_containers_to_stop() {
    docker ps --format '{{.ID}}\t{{.Names}}' | while IFS=$'\t' read -r container_id container_name; do
        local label_value
        label_value=$(docker inspect --format="{{ index .Config.Labels \"$LABEL_STOP\" }}" "$container_id" 2>/dev/null)
        if [[ "$label_value" == "true" ]]; then
            echo "${container_id}:${container_name}"
        fi
    done
}

# Main backup logic
main() {
    log_info "Starting Docker backup using restic"
    log_info "Repository: $RESTIC_REPOSITORY"
    log_info "Backup directory: $DATA_DIR"

    if [[ $DRY_RUN -eq 1 ]]; then
        log_info "=== DRY RUN MODE - No actions will be performed ==="
    fi

    # Initialize/check repository (skip during dry run)
    if [[ $DRY_RUN -eq 0 ]]; then
        init_restic_repo
    else
        log_info "[DRY RUN] Would check/initialize restic repository"
    fi

    # Find containers that need to be stopped
    log_info "Checking for containers with backup.stop label..."
    local containers_to_stop
    containers_to_stop=$(get_containers_to_stop)

    if [[ -n "$containers_to_stop" ]]; then
        while IFS= read -r container_info; do
            [[ -z "$container_info" ]] && continue
            local container_id="${container_info%%:*}"
            local container_name="${container_info##*:}"

            if [[ $DRY_RUN -eq 0 ]]; then
                log_info "Stopping container: $container_name"
                if docker stop "$container_id"; then
                    STOPPED_CONTAINERS+=("$container_info")
                else
                    log_error "Failed to stop container $container_name"
                    FAILED=1
                fi
            else
                log_info "[DRY RUN] Would stop container: $container_name"
            fi
        done <<< "$containers_to_stop"

        log_info "Stopped ${#STOPPED_CONTAINERS[@]} container(s) for backup"
    else
        log_info "No containers with backup.stop label found"
    fi

    # Take single restic snapshot of entire /srv/docker
    if [[ $DRY_RUN -eq 1 ]]; then
        log_info "[DRY RUN] Would run: restic backup --tag docker $DATA_DIR"
    else
        log_info "Taking restic snapshot of $DATA_DIR..."
        if restic backup --tag "docker" "$DATA_DIR"; then
            log_info "Backup completed successfully"
        else
            log_error "Backup failed"
            FAILED=1
        fi
    fi

    # Prune old snapshots (keep last 7 daily, 4 weekly, 12 monthly)
    if [[ $DRY_RUN -eq 0 && $FAILED -eq 0 ]]; then
        log_info "Pruning old snapshots..."
        restic forget --keep-daily 7 --keep-weekly 4 --prune || log_warn "Pruning failed, but backup succeeded"
    elif [[ $DRY_RUN -eq 1 ]]; then
        log_info "[DRY RUN] Would prune old snapshots"
    fi

    if [[ $FAILED -ne 0 ]]; then
        log_error "Backup completed with errors"
        exit 1
    fi

    log_info "Backup complete"
    exit 0
}

main "$@"
